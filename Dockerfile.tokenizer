FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /tokenizer ./cmd/tokenizer

FROM gcr.io/distroless/static-debian12
COPY --from=builder /tokenizer /tokenizer
COPY migrations/ /migrations/
EXPOSE 8080
ENTRYPOINT ["/tokenizer"]
