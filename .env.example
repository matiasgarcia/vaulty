# PostgreSQL
DATABASE_URL=postgres://vault:vault@localhost:5432/vault?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# KMS (LocalStack in dev)
KMS_KEY_ARN=<create with: aws --endpoint-url=http://localhost:4566 kms create-key>
KMS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# HMAC key for PAN blind index (base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
HMAC_KEY=

# CVV TTL
CVV_TTL=1h

# Service ports
PORT_TOKENIZER=8080
PORT_PROXY=8081

# Proxy → Tokenizer connection
TOKENIZER_BASE_URL=http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
